# ===========================================
# VirtualJobSeekerAgent 环境变量配置模板
# ===========================================

### Configure Your API Key

SMITHERY_API_KEY=your_api_key_here
OPENAI_API_KEY=your_api_key_here

GMAIL_MCP_CREDS_PATH=your-credentials.json
GOOGLE_CLIENT_ID=your_google_client_id_here

### 环境配置

# 部署环境配置 (Chrome扩展和Flask服务器)
# 本地开发: local 或 development  
# 生产部署: production 或 railway
ENVIRONMENT=local

### 后端服务器配置 (Flask - 可选)

# 本地开发时通常不需要设置这些，会自动检测
# PORT=5000               # 端口号 (默认5000，Railway会自动设置)
# DEBUG=true             # 调试模式 (本地默认true，生产默认false)  
# HOST=127.0.0.1         # 主机地址 (本地默认127.0.0.1，生产默认0.0.0.0)

# Railway会自动设置的变量 (无需手动设置)
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PROJECT_ID=xxx



# ===========================================
# 配置说明：
# ===========================================
# 
# 1. 复制此文件为 .env：
# 
# 2. 填入你的实际配置值
# 
# 3. 确保 .env 已添加到 .gitignore 中
# 
# 4. 团队成员各自使用自己的 Google Client ID
#    避免 API 配额冲突
# 
# ===========================================
